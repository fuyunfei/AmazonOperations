generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 快照类报表（除产品报表外的所有报表）
// 存储策略：按 fileType upsert，每次上传同类型报表整条替换
model ContextFile {
  id           String   @id @default(cuid())
  fileType     String   @unique  // 见 fileType 枚举：search_terms / campaign_3m / us_campaign_30d / placement_us_30d / inventory / keyword_monitor / cost_mgmt / aba_search
  fileName     String            // 原始文件名，如 "search_terms_30d.xlsx"
  uploadDate   DateTime @default(now())
  snapshotDate String            // 来自报表 D2 字段的结束日期，如 "2026-04-08"
  parsedRows   String            // JSON string: Row[]
}

// 产品报表时序数据
// 存储策略：按 (asin, date) upsert，不同日期数据永远保留
model ProductMetricDay {
  id      String @id @default(cuid())
  asin    String
  date    String   // "2026-04-08"（来自报表 D2 字段的结束日期）
  metrics String   // JSON string: { gmv, orders, units, returns, ad_spend, ad_sales, ad_orders, impressions, clicks, sessions, ocr }

  @@unique([asin, date])
}

// 品类 → ASIN 列表映射
// 存储策略：手动维护，通过 seed.ts 初始化
model CategoryMap {
  id          String @id @default(cuid())
  categoryKey String @unique   // "mattress" | "pump" | "scooter"
  displayName String           // "床垫" | "充气泵" | "电动滑板车"
  asins       String           // JSON string: string[]，如 '["B0GD7BF2TZ", "B0GD7K1TC9"]'
}

// ASIN 级别配置（品类归属 + 产品阶段）
// 存储策略：手动维护，通过 seed.ts 初始化
model AsinConfig {
  id          String   @id @default(cuid())
  asin        String   @unique
  categoryKey String              // 与 CategoryMap.categoryKey 对应
  stage       String              // "launch" | "growth" | "mature"
  displayName String?             // 可选展示名，如 "Queen 4\" 沙发床垫"
  updatedAt   DateTime @updatedAt
}

// 每日告警快照（ASIN × 指标粒度）
// 存储策略：上传产品报表后，按 snapshotDate 全量重写（deleteMany + batch insert）
model Alert {
  id           String   @id @default(cuid())
  asin         String
  categoryKey  String                    // "mattress" | "pump" | "scooter"
  metric       String                    // "acos_red" | "sessions_drop" | "inventory_low" | "budget_utilization" | ...
  level        String                    // "red" | "yellow"
  currentValue Float                     // 实际值，如 0.824（ACOS 82.4%）
  threshold    Float                     // 触发阈值，如 0.55
  stage        String                    // "launch" | "growth" | "mature"
  suggestion   String                    // 建议操作文本
  snapshotDate String                    // 产品报表日期，如 "2026-04-09"
  createdAt    DateTime @default(now())

  @@unique([asin, metric, snapshotDate])
  @@index([categoryKey, snapshotDate])
}

// Chat 对话 Session
model Session {
  id        String    @id @default(cuid())
  title     String    @default("新对话")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

// Session 内的消息（user / assistant 轮次）
model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String              // "user" | "assistant"
  content   String
  toolCalls String?             // JSON string: ToolCallRecord[]，仅 assistant 消息有
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}
